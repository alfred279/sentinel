# Copy to .env and fill in. NEVER commit .env.

TZ=America/Chicago

# Database
DB_USER=sentinel
DB_PASSWORD=change_me_strong_password
DB_NAME=sentinel

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# Camera credential encryption key — generate with: openssl rand -hex 32
# If you lose this, saved camera passwords become unrecoverable (re-add cameras).
HUB_ENCRYPTION_KEY=
